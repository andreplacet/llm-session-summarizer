# ── Streamlit Cloud Secrets ──
# Copie o conteúdo deste arquivo e cole em:
#   share.streamlit.io → seu app → Settings → Secrets
#
# NUNCA commite o arquivo secrets.toml real.
# O .gitignore já bloqueia .streamlit/secrets.toml

# Chave da API Gemini (obrigatória se quiser usar Gemini no Cloud)
GEMINI_API_KEY = "your-gemini-api-key-here"
